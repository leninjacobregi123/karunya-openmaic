# Env file for docker-compose.remote.yml. Copy to `.env` (compose auto-loads
# it) and change every value below before exposing this to anyone but you.
#
#   cp .env.remote.example .env

# --- Secrets (CHANGE THESE) ---------------------------------------------------
POSTGRES_PASSWORD=change-me-postgres
MINIO_ROOT_PASSWORD=change-me-minio
SESSION_SECRET=change-me-to-a-long-random-string

# --- Dev accounts --------------------------------------------------------------
# true  = seed admin@karunya.edu/teacher123 + student1/student2 (weak, well-known
#         passwords - fine for a first smoke test, NOT for anything real).
# false = skip seeding; you'll need another way to create accounts (real AD/LDAP
#         wiring is a documented follow-up in docs/karunya-architecture.md).
MAIC_SEED_DEV_USERS=true

# --- Models ----------------------------------------------------------------
# The LLM needs an OpenAI-compatible server (e.g. vLLM) reachable at :8001 -
# either one you already run yourself (external), or the containerized
# `vllm` service in this file (enable with `--profile local-vllm`, see the
# file header). Format: "lemonade:<exact model name your vLLM instance
# serves>" - e.g. lemonade:Qwen/Qwen2.5-32B-Instruct. No default: this MUST
# match whatever vLLM actually serves (check its startup log / `--model`
# flag, or GET http://<vllm-host>:<port>/v1/models).
#
# Using the containerized `vllm` service (profile local-vllm, serves
# openai/gpt-oss-20b by default)? Use this exact value:
# MAIC_DEFAULT_MODEL=lemonade:openai/gpt-oss-20b
MAIC_DEFAULT_MODEL=lemonade:REPLACE_WITH_YOUR_VLLM_MODEL_NAME

# Where the app should reach vLLM. Leave unset if vLLM runs directly on THIS
# host (defaults to http://host.docker.internal:8001/v1). Set to
# http://vllm:8000/v1 if using the containerized `vllm` service (profile
# local-vllm). Set to a full URL (scheme + /v1 path) if vLLM runs on a
# different machine, e.g. http://192.168.6.249:8001/v1.
#MAIC_VLLM_BASE_URL=

# --- Ports (host-side; change if already taken) ------------------------------
MAIC_APP_PORT=3000
MAIC_MINIO_CONSOLE_PORT=9001
